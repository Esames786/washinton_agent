APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

LOG_CHANNEL=stack

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=homestead
DB_USERNAME=homestead
DB_PASSWORD=secret

BROADCAST_DRIVER=log
CACHE_DRIVER=file
SESSION_DRIVER=file
SESSION_LIFETIME=120
QUEUE_DRIVER=sync

REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_DRIVER=smtp
MAIL_HOST=smtp.mailtrap.io
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null

PUSHER_APP_ID=
PUSHER_APP_KEY=
PUSHER_APP_SECRET=
PUSHER_APP_CLUSTER=mt1

MIX_PUSHER_APP_KEY="${PUSHER_APP_KEY}"
MIX_PUSHER_APP_CLUSTER="${PUSHER_APP_CLUSTER}"

# Central Gateway
CENTRAL_GATEWAY_BASE=https://roadya.com
CENTRAL_GATEWAY_API_KEY=
CENTRAL_GATEWAY_API_SECRET=
CENTRAL_GATEWAY_TIMEOUT=30

# AutoHaulingQuotes.com API credentials
AUTOHAUL_PLATFORM=washington-autohaul
AUTOHAUL_API_KEY=
AUTOHAUL_API_SECRET=

# Central Gateway client portal URLs
GATEWAY_PORTAL_WASHINGTON=
GATEWAY_PORTAL_AUTOHAUL=

# HR Portal Bridge — points to washinton_hr (hrwashinton.shawntransport.com)
HRPORTAL_BASE_URL=https://hrwashinton.shawntransport.com
HRPORTAL_SHARED_KEY=
HRPORTAL_AGENT_LOGIN_ENDPOINT=/bridge/agent/login
HRPORTAL_AGENT_STATUS_ENDPOINT=/bridge/agent/status

# Inbound bridge key — HR portal sends this when calling Washington bridge endpoints
WASHINGTON_BRIDGE_SHARED_KEY=
